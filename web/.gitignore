# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Next.js / Vercel: https://nextjs.org/docs/app/api-reference/config/next-config-js
#
# Always keep these under version control (do not add ignore rules that match them):
#   next.config.{js,mjs,ts}, tsconfig.json, package.json, package-lock.json, postcss.config.*, etc.

# Dependencies (any depth under web/)
**/node_modules/
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
.next/
out/

# Testing
/coverage

# Production / misc build
/build

.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment — never commit machine-specific secrets (use `.env*.local` locally).
.env*.local
# Broad `.env*` catches stray `.env`, `.env.production`, etc.; template must stay tracked:
.env*
!.env.example
!**/.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

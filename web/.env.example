# Copy to .env.local and fill in values (never commit .env.local)

BROWSER=none
NODE_ENV=development

# API origin only (no /api path suffix). Axios calls use paths like /api/...
# Override in `.env.local` if your backend uses another host/port (never commit .env.local).
NEXT_PUBLIC_API_URL=http://localhost:5046

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Google Identity Services / custom OAuth UI
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
